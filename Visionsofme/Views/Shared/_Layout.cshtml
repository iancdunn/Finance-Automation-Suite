<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Visionsofme</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen font-sans text-gray-800">
    <nav class="bg-black shadow-md mb-8">
        <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
            <a class="text-xl font-bold text-white hover:text-gray-300 transition" asp-controller="Home" 
            asp-action="Index">Visionsofme</a>
            @if(User.Identity?.IsAuthenticated == true){
                <a href="/logout" 
                class="border border-white text-white hover:bg-gray-700 font-semibold py-1 px-4 rounded text-sm">
                    Logout
                </a>
            }
        </div>
    </nav>
    
    <div class="container mx-auto max-w-6xl">
        @if(TempData["message"] != null){
            <div class="bg-blue-100 text-blue-700 p-4 mb-6 rounded w-fit" role="alert">
                <p>@TempData["message"]</p>
            </div>
        }

        @if(TempData["error"] != null){
            <div class="bg-red-100 text-red-700 p-4 mb-6 rounded w-fit" role="alert">
                <p>@TempData["error"]</p>
            </div>
        }

        @RenderBody()
    </div>
</body>
</html>